{
  "name": "book-review-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "prestart": "node ./scripts/ensure-node-version.mjs",
    "start": "ng serve --host 127.0.0.1 --port 4200 --proxy-config proxy.conf.cjs --disable-host-check",
    "dev": "npm run start",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "predb:migrate": "node ./scripts/ensure-node-version.mjs",
    "db:migrate": "npm run migrate --prefix api",
    "predev:api": "node ./scripts/ensure-node-version.mjs",
    "dev:api": "npm run dev --prefix api",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --configuration production --stats-json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --code-coverage",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadless",
    "e2e": "playwright test",
    "lint": "ng lint",
    "check": "npm run lint && npm run build:prod && npm run test:ci"
  },
  "dependencies": {
    "@angular/animations": "^18.1.0",
    "@angular/common": "^18.1.0",
    "@angular/compiler": "^18.1.0",
    "@angular/core": "^18.1.0",
    "@angular/forms": "^18.1.0",
    "@angular/platform-browser": "^18.1.0",
    "@angular/platform-browser-dynamic": "^18.1.0",
    "@angular/router": "^18.1.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "^0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.1.0",
    "@angular-eslint/builder": "^18.0.1",
    "@angular-eslint/eslint-plugin": "^18.0.1",
    "@angular-eslint/eslint-plugin-template": "^18.0.1",
    "@angular-eslint/schematics": "^18.0.1",
    "@angular-eslint/template-parser": "^18.0.1",
    "@angular/cli": "^18.1.0",
    "@angular/compiler-cli": "^18.1.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jasmine": "^5.1.0",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "jasmine-core": "^5.1.1",
    "karma": "^6.4.2",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.4.0"
  }
}
