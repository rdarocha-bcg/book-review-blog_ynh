# Copy to .env and adjust. Used by Fastify API and migrate script.
# English comments only (project convention).

NODE_ENV=development

HOST=127.0.0.1
PORT=3000

# Comma-separated YunoHost usernames treated as app admins (must match proxy DEV_YNH_USER in dev).
ADMIN_USERNAMES=devuser

# Trust SSO-style headers: auto | always | never (see api/src/sso.ts).
TRUST_SSO_HEADERS=auto

# Database — defaults match docker-compose.yml at repo root.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=bookapp
DATABASE_PASSWORD=bookapp_local
DATABASE_NAME=book_review_blog
