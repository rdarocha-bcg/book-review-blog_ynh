#!/bin/bash
source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# INSTALL NODE.JS
#=================================================
ynh_script_progression --message="Installing Node.js $nodejs_version..." --weight=15

ynh_install_nodejs --nodejs_version=$nodejs_version

#=================================================
# COPY APP SOURCES
#=================================================
ynh_script_progression --message="Setting up source files..." --weight=5

ynh_copy_app_sources "$install_dir/src"

mkdir -p "$install_dir/src/src/assets"
cp "$pkg_dir/conf/site.config.json" "$install_dir/src/src/assets/site.config.json"

#=================================================
# PATHS & ENVIRONMENT
#=================================================
if [ "$path" = "/" ]; then
    base_href="/"
    api_path="/api"
else
    base_href="$path/"
    api_path="$path/api"
fi

ynh_app_setting_set --app=$app --key=admin_usernames --value="$admin_usernames"

sed -e "s|__API_PATH__|$api_path|g" -e "s|__DOMAIN__|$domain|g" \
    "$pkg_dir/conf/environment.prod.ts" \
    > "$install_dir/src/src/environments/environment.prod.ts"

#=================================================
# BUILD ANGULAR
#=================================================
ynh_script_progression --message="Building Angular app (this may take a few minutes)..." --weight=35

pushd "$install_dir/src"
    ynh_use_nodejs
    ynh_exec_warn_less $ynh_node_load_PATH npm ci --production=false
    ynh_exec_warn_less $ynh_node_load_PATH npx ng build --configuration production --base-href "$base_href"
popd

#=================================================
# DEPLOY STATIC FILES
#=================================================
ynh_script_progression --message="Deploying static files..." --weight=3

mkdir -p "$install_dir/www"
cp -a "$install_dir/src/dist/book-review-blog/." "$install_dir/www/"

#=================================================
# BUILD & DEPLOY API
#=================================================
ynh_script_progression --message="Building API..." --weight=15

pushd "$install_dir/src/api"
    ynh_use_nodejs
    ynh_exec_warn_less $ynh_node_load_PATH npm ci
    ynh_exec_warn_less $ynh_node_load_PATH npm run build
popd

mkdir -p "$install_dir/api"
cp -a "$install_dir/src/api/package.json" "$install_dir/src/api/package-lock.json" "$install_dir/api/"
cp -a "$install_dir/src/api/dist" "$install_dir/api/"
cp -a "$install_dir/src/api/migrations" "$install_dir/api/"

pushd "$install_dir/api"
    ynh_use_nodejs
    ynh_exec_warn_less $ynh_node_load_PATH npm ci --omit=dev
popd

cat > "$install_dir/api/.env" <<EOF
HOST=127.0.0.1
PORT=$port
NODE_ENV=production
DATABASE_HOST=127.0.0.1
DATABASE_USER=$db_user
DATABASE_PASSWORD=$db_pwd
DATABASE_NAME=$db_name
ADMIN_USERNAMES=$admin_usernames
TRUST_SSO_HEADERS=auto
EOF

chmod 640 "$install_dir/api/.env"
chown $app:$app "$install_dir/api/.env"
chown -R $app:$app "$install_dir/api"

#=================================================
# DATABASE MIGRATIONS
#=================================================
ynh_script_progression --message="Running database migrations..." --weight=3

ynh_exec_as $app "cd \"$install_dir/api\" && node dist/migrate.js"

#=================================================
# API STARTUP WRAPPER (Node on PATH)
#=================================================
node_bin="$(command -v node)"
cat > "$install_dir/api/run.sh" <<EOF
#!/bin/bash
set -euo pipefail
export PATH="$(dirname "$node_bin"):\${PATH}"
cd "$install_dir/api"
exec node dist/index.js
EOF
chmod +x "$install_dir/api/run.sh"
chown $app:$app "$install_dir/api/run.sh"

chown -R $app:www-data "$install_dir/www"
chmod -R 750 "$install_dir/www"

#=================================================
# SYSTEMD
#=================================================
ynh_script_progression --message="Configuring systemd service..." --weight=2

ynh_add_systemd_config

ynh_systemd_action --service_name=$app --action=start --log_path=systemd

#=================================================
# NGINX
#=================================================
ynh_script_progression --message="Configuring NGINX..." --weight=3

ynh_add_nginx_config

#=================================================
# CLEAN SOURCES
#=================================================
rm -rf "$install_dir/src"

#=================================================
# END
#=================================================
ynh_script_progression --message="Installation completed!" --last
