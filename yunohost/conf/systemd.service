[Unit]
Description=Book Review Blog API (Fastify + MariaDB)
After=network.target mariadb.service

[Service]
Type=simple
User=__APP__
Group=__APP__
WorkingDirectory=__INSTALL_DIR__/api
EnvironmentFile=__INSTALL_DIR__/api/.env
ExecStart=__INSTALL_DIR__/api/run.sh
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
